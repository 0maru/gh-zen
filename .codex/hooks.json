{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "apply_patch|Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/scripts/agent-go-check.sh\"",
            "timeout": 120,
            "statusMessage": "Running Go fast gate"
          }
        ]
      }
    ]
  }
}
