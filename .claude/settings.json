{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|MultiEdit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "\"$(git rev-parse --show-toplevel)/scripts/agent-go-check.sh\"",
            "timeout": 120
          }
        ]
      }
    ]
  }
}
